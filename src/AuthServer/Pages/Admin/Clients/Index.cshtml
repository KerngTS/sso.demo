@page "/Admin/Clients"
@model AuthServer.Pages.Admin.Clients.IndexModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "admin,ClientManager")]
@{
    ViewData["Title"] = "Client 管理";
}

<h2>@ViewData["Title"]</h2>

@if (TempData["ClientSecret"] is string secret)
{
    <div class="alert alert-success alert-dismissible fade show">
        <strong>Client Secret（僅顯示一次！請立即儲存）：</strong><br />
        <code class="text-break">@secret</code>
        <br /><small>ClientId: <code>@TempData["ClientId"]</code></small>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="get" class="row g-2 mb-3 align-items-end">
    <div class="col-md-4">
        <label class="form-label" style="font-size:12px; color: var(--fg) !important;">關鍵字 (ClientId / 顯示名稱)</label>
        <input name="search" class="form-control" placeholder="搜尋 ClientId 或名稱..." value="@Model.Search" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary">搜尋</button>
        <a class="btn btn-outline-secondary" asp-page="Index">清除</a>
    </div>
    <div class="col-auto ms-auto">
        <a class="btn btn-primary" asp-page="Create">新增 Client</a>
    </div>
</form>

@if (Model.Clients.Count == 0)
{
    <div class="alert alert-info">尚無 Client 資料。</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Client識別碼</th>
                <th>類型</th>
                <th>顯示名稱</th>
                <th>授權流程</th>
                <th style="width:180px">操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var client in Model.Clients)
            {
                <tr>
                    <td><code>@client.ClientId</code></td>
                    <td>
                        @if (client.ClientType == "confidential")
                        {
                            <span class="badge bg-warning text-dark">機密</span>
                        }
                        else
                        {
                            <span class="badge bg-info text-dark">公開</span>
                        }
                    </td>
                    <td>@client.DisplayName</td>
                    <td>@client.GrantTypes</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" asp-page="Edit" asp-route-clientId="@client.ClientId">編輯</a>
                        <button class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('確定刪除 Client @client.ClientId 嗎？') ? location.href='@Url.Page("Index", new { handler = "Delete", clientId = client.ClientId })' : void(0)">
                            刪除
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-page="Index" asp-route-search="@Model.Search" asp-route-page="@(Model.Page - 1)">← 上一頁</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">第 @Model.Page / @Model.TotalPages 頁</span>
                </li>
                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-page="Index" asp-route-search="@Model.Search" asp-route-page="@(Model.Page + 1)">下一頁 →</a>
                </li>
            </ul>
        </nav>
    }
}
