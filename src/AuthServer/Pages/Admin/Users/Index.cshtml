@page "/Admin/Users"
@model AuthServer.Pages.Admin.Users.IndexModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "admin,UserManager")]
@{
    ViewData["Title"] = "用戶管理";
}

<h2>@ViewData["Title"]</h2>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-5">
        <input name="search" class="form-control" placeholder="搜尋帳號或 Email..." value="@Model.Search" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary">搜尋</button>
        <a class="btn btn-outline-secondary" asp-page="Index">清除</a>
    </div>
    <div class="col-auto ms-auto">
        <a class="btn btn-primary" asp-page="Create">新增用戶</a>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>帳號</th>
            <th>電子郵件</th>
            <th>角色</th>
            <th>狀態</th>
            <th style="width:100px">操作</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model.Users)
        {
            <tr>
                <td><code>@user.UserName</code></td>
                <td>@user.Email</td>
                <td>
                    @foreach (var role in user.Roles)
                    {
                        <span class="badge bg-secondary me-1">@role</span>
                    }
                </td>
                <td>
                    @if (user.IsDisabled)
                    {
                        <span class="badge bg-danger">已禁用</span>
                    }
                    else
                    {
                        <span class="badge bg-success">啟用中</span>
                    }
                </td>
                <td>
                    <a class="btn btn-sm btn-outline-primary" asp-page="Edit" asp-route-id="@user.Id">編輯</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                <a class="page-link" asp-page="Index" asp-route-search="@Model.Search" asp-route-page="@(Model.Page - 1)">← 上一頁</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">第 @Model.Page / @Model.TotalPages 頁</span>
            </li>
            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-page="Index" asp-route-search="@Model.Search" asp-route-page="@(Model.Page + 1)">下一頁 →</a>
            </li>
        </ul>
    </nav>
}
