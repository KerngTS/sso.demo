@page "/Admin/Roles"
@model AuthServer.Pages.Admin.Roles.IndexModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "admin")]
@{
    ViewData["Title"] = "角色管理";
}

<h2>@ViewData["Title"]</h2>

@if (TempData["RoleMessage"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="get" class="row g-2 mb-3 align-items-end">
    <div class="col-md-4">
        <label class="form-label" style="font-size:12px; color: var(--fg) !important;">關鍵字 (角色名稱)</label>
        <input name="search" class="form-control" placeholder="搜尋角色名稱..." value="@Model.Search" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary">搜尋</button>
        <a class="btn btn-outline-secondary" asp-page="Index">清除</a>
    </div>
    <div class="col-auto ms-auto">
        <a class="btn btn-primary" asp-page="Create">新增角色</a>
    </div>
</form>

@if (Model.Roles.Count == 0)
{
    <div class="alert alert-info">尚無角色資料。</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>角色名稱</th>
                <th class="text-end">使用者人數</th>
                <th style="width:180px">操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var role in Model.Roles)
            {
                <tr>
                    <td><code>@role.Name</code></td>
                    <td class="text-end">
                        <span class="badge bg-secondary">@role.UserCount</span>
                    </td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" asp-page="Edit" asp-route-name="@role.Name">編輯</a>
                        <button class="btn btn-sm btn-outline-danger"
                                @(role.UserCount > 0 ? "disabled title=無法刪除：有 " + role.UserCount + " 個使用者持有此角色" : "")
                                onclick="return confirm('確定刪除角色 @role.Name 嗎？') ? location.href='@Url.Page("Index", new { handler = "Delete", name = role.Name })' : void(0)">
                            刪除
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-page="Index" asp-route-search="@Model.Search" asp-route-page="@(Model.Page - 1)">← 上一頁</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">第 @Model.Page / @Model.TotalPages 頁</span>
                </li>
                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-page="Index" asp-route-search="@Model.Search" asp-route-page="@(Model.Page + 1)">下一頁 →</a>
                </li>
            </ul>
        </nav>
    }
}
