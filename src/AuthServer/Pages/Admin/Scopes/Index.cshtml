@page "/Admin/Scopes"
@model AuthServer.Pages.Admin.Scopes.IndexModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "admin,ScopeManager")]
@{
    ViewData["Title"] = "Scope 管理";
}

<h2>@ViewData["Title"]</h2>
<p>
    <a class="btn btn-primary" asp-page="Create">新增 Scope</a>
</p>

@if (Model.Scopes.Count == 0)
{
    <div class="alert alert-info">尚無 Scope 資料。</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>名稱</th>
                <th>顯示名稱</th>
                <th>描述</th>
                <th>資源</th>
                <th style="width:180px">操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var scope in Model.Scopes)
            {
                <tr>
                    <td><code>@scope.Name</code></td>
                    <td>@scope.DisplayName</td>
                    <td>@scope.Description</td>
                    <td>@scope.Resources</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" asp-page="Edit" asp-route-name="@scope.Name">編輯</a>
                        <button class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('確定刪除 Scope @scope.Name 嗎？') ? location.href='@Url.Page("Index", new { handler = "Delete", name = scope.Name })' : void(0)">
                            刪除
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
