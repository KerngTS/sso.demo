@page "/Admin/Scopes"
@model AuthServer.Pages.Admin.Scopes.IndexModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "admin,ScopeManager")]
@{
    ViewData["Title"] = "Scope 管理";
}

<h2>@ViewData["Title"]</h2>

<form method="get" class="row g-2 mb-3 align-items-end">
    <div class="col-md-4">
        <label class="form-label" style="font-size:12px; color: var(--fg) !important;">關鍵字 (Scope名稱 / 顯示名稱)</label>
        <input name="search" class="form-control" placeholder="搜尋 Scope 名稱或顯示名稱..." value="@Model.Search" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary">搜尋</button>
        <a class="btn btn-outline-secondary" asp-page="Index">清除</a>
    </div>
    <div class="col-auto ms-auto">
        <a class="btn btn-primary" asp-page="Create">新增 Scope</a>
    </div>
</form>

@if (Model.Scopes.Count == 0)
{
    <div class="alert alert-info">尚無 Scope 資料。</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>名稱</th>
                <th>顯示名稱</th>
                <th>描述</th>
                <th>資源</th>
                <th style="width:180px">操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var scope in Model.Scopes)
            {
                <tr>
                    <td><code>@scope.Name</code></td>
                    <td>@scope.DisplayName</td>
                    <td>@scope.Description</td>
                    <td>@scope.Resources</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" asp-page="Edit" asp-route-name="@scope.Name">編輯</a>
                        <button class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('確定刪除 Scope @scope.Name 嗎？') ? location.href='@Url.Page("Index", new { handler = "Delete", name = scope.Name })' : void(0)">
                            刪除
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-page="Index" asp-route-search="@Model.Search" asp-route-page="@(Model.Page - 1)">← 上一頁</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">第 @Model.Page / @Model.TotalPages 頁</span>
                </li>
                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-page="Index" asp-route-search="@Model.Search" asp-route-page="@(Model.Page + 1)">下一頁 →</a>
                </li>
            </ul>
        </nav>
    }
}
