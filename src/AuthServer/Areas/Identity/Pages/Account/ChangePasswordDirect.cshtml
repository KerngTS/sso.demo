@page
@model ChangePasswordDirectModel
@{
    ViewData["Title"] = "修改密碼";
}

<div class="login-card">
    <div class="login-logo">
        <div class="login-logo-icon">🔐</div>
        <div>
            <div class="login-logo-text">SSO</div>
            <div class="login-logo-sub">PASSWORD SELF-SERVICE</div>
        </div>
    </div>

    <form id="change-password-form" method="post" novalidate>
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 validation-summary-errors" role="alert"></div>

        <div class="field">
            <label asp-for="Input.Email">電子郵件 (Email)</label>
            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="user@example.com" autofocus />
            <span asp-validation-for="Input.Email" class="text-danger" style="font-size:12px;"></span>
        </div>

        <div class="field">
            <label asp-for="Input.OldPassword">目前舊密碼</label>
            <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" placeholder="••••••••" />
            <span asp-validation-for="Input.OldPassword" class="text-danger" style="font-size:12px;"></span>
        </div>

        <div class="field">
            <label asp-for="Input.NewPassword">新密碼</label>
            <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" placeholder="至少 6 個字元" />
            <span asp-validation-for="Input.NewPassword" class="text-danger" style="font-size:12px;"></span>
        </div>

        <div class="field">
            <label asp-for="Input.ConfirmPassword">確認新密碼</label>
            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="再次輸入新密碼" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger" style="font-size:12px;"></span>
        </div>

        <button type="submit" class="btn btn-primary mb-3">確認修改</button>
        
        <div class="text-center mt-3">
            <a class="forgot-link" asp-page="./Login" style="font-size:13px;">返回登入</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
