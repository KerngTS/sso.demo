@page "/fetchdata"
@attribute [Authorize]
@using System.Net.Http
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>從 Web API 取得資料</PageTitle>

<h1>呼叫 .NET Web API</h1>

<p>此頁面使用登入後取得的 Access Token，呼叫遠端 Web API 的受保護端點。</p>

@if (forecast == null)
{
    <p><em>載入中...</em></p>
}
else
{
    <div class="alert alert-success d-flex justify-content-between align-items-center">
        <div>
            <strong>✅ 身份驗證成功!</strong> 您以 <code>@userName</code> 的身份呼叫了 API。
        </div>
        <button class="btn btn-sm btn-outline-danger" @onclick="BeginSignOut">登出帳號</button>
    </div>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>日期</th>
                <th>溫度 (°C)</th>
                <th>溫度 (°F)</th>
                <th>摘要</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in forecast)
            {
                <tr>
                    <td>@item.Date</td>
                    <td>@item.TemperatureC</td>
                    <td>@item.TemperatureF</td>
                    <td>@item.Summary</td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="d-flex gap-2">
    <button class="btn btn-primary" @onclick="CallWebApiAsync">重新整理資料</button>
    @if (forecast != null)
    {
        <button class="btn btn-danger" @onclick="BeginSignOut">登出帳號</button>
    }
</div>

@code {
    private WeatherForecast[]? forecast;
    private string? userName;

    protected override async Task OnInitializedAsync()
    {
        await CallWebApiAsync();
    }

    private void BeginSignOut()
    {
        // 觸發 OIDC 單一登出 (SLO) 流程
        Navigation.NavigateToLogout("authentication/logout");
    }

    private async Task CallWebApiAsync()
    {
        try
        {
            // 使用帶 Token 的 HttpClient 呼叫 Web API
            var client = HttpClientFactory.CreateClient("WebApi");
            var response = await client.GetFromJsonAsync<WeatherApiResponse>("/api/weatherforecast");

            if (response != null)
            {
                userName = response.User;
                forecast = response.Forecast;
            }
        }
        catch (Exception ex)
        {
            userName = $"錯誤: {ex.Message}";
            forecast = null;
        }
    }

    private class WeatherApiResponse
    {
        public string? User { get; set; }
        public WeatherForecast[]? Forecast { get; set; }
    }

    private class WeatherForecast
    {
        public DateOnly Date { get; set; }
        public int TemperatureC { get; set; }
        public int TemperatureF { get; set; }
        public string? Summary { get; set; }
    }
}
